# GitHub Personal Access Token
# Required for automated git commits in Docker containers
# Get your token from: https://github.com/settings/tokens
# The token needs push access to this repository
GITHUB_TOKEN=your_github_token_here

# Docker Architecture for Hugo binary
# amd64: Most servers (x86_64) - Hetzner, DigitalOcean, AWS, etc.
# arm64: Apple Silicon Macs, ARM servers
# Default: amd64
DOCKER_ARCH=amd64
